# ─────────────────────────────────────────────────────────────────
# Claude Control Center — 환경 변수 (모두 선택)
# 복사: cp env.example .env
# .env 는 .gitignore 로 제외되어 git 에 올라가지 않습니다.
# (이 파일 자체는 leading dot 없는 'env.example' 로 commit — 일부 도구가 .env* 쓰기를 차단)
# ─────────────────────────────────────────────────────────────────

# 서버 바인드
HOST=127.0.0.1
PORT=8080

# Claude Code CLI 가 사용하는 디렉토리 (기본: ~/.claude)
# CLAUDE_HOME=/Users/YOUR_USER/.claude

# Claude Code 전체 설정 파일 (기본: ~/.claude.json)
# CLAUDE_JSON=/Users/YOUR_USER/.claude.json

# Claude Desktop 앱 MCP 설정
#   macOS:    ~/Library/Application Support/Claude/claude_desktop_config.json
#   Linux:    ~/.config/Claude/claude_desktop_config.json
#   Windows:  %APPDATA%\Claude\claude_desktop_config.json
# CLAUDE_DESKTOP_CONFIG=/Users/YOUR_USER/Library/Application Support/Claude/claude_desktop_config.json

# 대시보드 자체 데이터 (기본: 홈 디렉토리)
# CLAUDE_DASHBOARD_DB=/Users/YOUR_USER/.claude-dashboard.db
# CLAUDE_DASHBOARD_TRANSLATIONS=/Users/YOUR_USER/.claude-dashboard-translations.json
# CLAUDE_DASHBOARD_CONFIG=/Users/YOUR_USER/.claude-dashboard-config.json

# 메모리 디렉토리 (기본: ~/.claude/projects/<cwd-slug>/memory — 자동 산출)
# CLAUDE_DASHBOARD_MEMORY_DIR=/Users/YOUR_USER/.claude/projects/-Users-YOUR_USER-claude-dashboard/memory
